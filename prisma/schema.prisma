generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["civic", "users", "governance", "ai_ops", "ops"]
}

// ── civic schema ──────────────────────────────────────────────────────────────

model Region {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String    @unique @db.VarChar(20)
  name        String    @db.VarChar(100)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  countries   Country[]
  @@map("regions")
  @@schema("civic")
}

model Country {
  id                     String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                   String   @unique @db.Char(3)
  name                   String   @db.VarChar(100)
  nameLocal              String?  @map("name_local")
  regionId               String   @map("region_id") @db.Uuid
  flagEmoji              String?  @map("flag_emoji") @db.VarChar(10)
  governanceType         String   @map("governance_type") @db.VarChar(100)
  headOfStateRole        String?  @map("head_of_state_role")
  headOfGovernmentRole   String?  @map("head_of_government_role")
  authorityName          String   @map("authority_name") @db.VarChar(200)
  authorityAbbr          String?  @map("authority_abbr") @db.VarChar(20)
  authorityPortal        String?  @map("authority_portal") @db.VarChar(500)
  voterHelpline          String?  @map("voter_helpline") @db.VarChar(50)
  votingAge              Int      @default(18) @map("voting_age") @db.SmallInt
  compulsoryVoting       Boolean  @default(false) @map("compulsory_voting")
  compulsoryFineAmount   Decimal? @map("compulsory_fine_amount") @db.Decimal(10, 2)
  compulsoryFineCurrency String?  @map("compulsory_fine_currency") @db.Char(3)
  registrationModel      String   @map("registration_model") @db.VarChar(20)
  electoralSystemLower   String?  @map("electoral_system_lower")
  electoralSystemUpper   String?  @map("electoral_system_upper")
  complexityScore        Int?     @map("complexity_score") @db.SmallInt
  legalVolatilityScore   Int?     @map("legal_volatility_score") @db.SmallInt
  isMvp                  Boolean  @default(false) @map("is_mvp")
  isActive               Boolean  @default(true) @map("is_active")
  deletedAt              DateTime? @map("deleted_at")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  region          Region               @relation(fields: [regionId], references: [id])
  jurisdictions   Jurisdiction[]
  electionTypes   ElectionType[]
  voterReqs       VoterRequirement[]
  officialDocs    OfficialDocument[]
  resolutionPaths ResolutionPath[]
  sources         SourceRegistry[]
  civicAxioms     CivicAxiom[]

  @@map("countries")
  @@schema("civic")
}

model Jurisdiction {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  countryId               String   @map("country_id") @db.Uuid
  parentId                String?  @map("parent_id") @db.Uuid
  name                    String   @db.VarChar(200)
  nameLocal               String?  @map("name_local")
  level                   String   @db.VarChar(30)
  code                    String?  @db.VarChar(20)
  population              BigInt?
  hasSeparateAuthority    Boolean  @default(false) @map("has_separate_authority")
  separateAuthorityName   String?  @map("separate_authority_name")
  separateAuthorityPortal String?  @map("separate_authority_portal")
  metadata                Json     @default("{}")
  isActive                Boolean  @default(true) @map("is_active")
  deletedAt               DateTime? @map("deleted_at")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  country        Country        @relation(fields: [countryId], references: [id])
  parent         Jurisdiction?  @relation("JurisdictionTree", fields: [parentId], references: [id])
  children       Jurisdiction[] @relation("JurisdictionTree")
  electionEvents ElectionEvent[]
  voterReqs      VoterRequirement[]

  @@map("jurisdictions")
  @@schema("civic")
}

model ElectionType {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  countryId           String   @map("country_id") @db.Uuid
  code                String   @db.VarChar(50)
  name                String   @db.VarChar(200)
  category            String   @db.VarChar(30)
  electoralSystem     String?  @map("electoral_system")
  totalSeats          Int?     @map("total_seats")
  frequencyYears      Int?     @map("frequency_years") @db.SmallInt
  termYears           Int?     @map("term_years") @db.SmallInt
  managedBy           String?  @map("managed_by")
  votingSystemDetails Json     @default("{}") @map("voting_system_details")
  isActive            Boolean  @default(true) @map("is_active")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  country        Country         @relation(fields: [countryId], references: [id])
  electionEvents ElectionEvent[]

  @@unique([countryId, code])
  @@map("election_types")
  @@schema("civic")
}

model ElectionEvent {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  electionTypeId       String   @map("election_type_id") @db.Uuid
  jurisdictionId       String?  @map("jurisdiction_id") @db.Uuid
  name                 String   @db.VarChar(200)
  electionDate         DateTime? @map("election_date") @db.Date
  registrationOpens    DateTime? @map("registration_opens") @db.Date
  registrationDeadline DateTime? @map("registration_deadline") @db.Date
  nominationDeadline   DateTime? @map("nomination_deadline") @db.Date
  campaignStart        DateTime? @map("campaign_start") @db.Date
  campaignEnd          DateTime? @map("campaign_end") @db.Date
  countingDate         DateTime? @map("counting_date") @db.Date
  certificationDate    DateTime? @map("certification_date") @db.Date
  status               String   @default("Scheduled") @db.VarChar(20)
  technologiesDeployed String[] @default([]) @map("technologies_deployed")
  specialProvisions    Json     @default("{}") @map("special_provisions")
  volatilityClass      String   @default("HIGH") @map("volatility_class") @db.VarChar(6)
  lastVerifiedAt       DateTime? @map("last_verified_at")
  isActive             Boolean  @default(true) @map("is_active")
  deletedAt            DateTime? @map("deleted_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  electionType   ElectionType    @relation(fields: [electionTypeId], references: [id])
  jurisdiction   Jurisdiction?   @relation(fields: [jurisdictionId], references: [id])
  stages         ElectionStage[]
  notifJobs      NotificationJob[]

  @@map("election_events")
  @@schema("civic")
}

model ElectionStage {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  stageNumber Int      @map("stage_number") @db.SmallInt
  name        String   @db.VarChar(100)
  status      String   @default("Upcoming") @db.VarChar(10)
  keyDate     DateTime? @map("key_date") @db.Date
  plainDesc   String?  @map("plain_desc")
  userAction  String?  @map("user_action")
  createdAt   DateTime @default(now()) @map("created_at")

  event ElectionEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, stageNumber])
  @@map("election_stages")
  @@schema("civic")
}

model VoterRequirement {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  countryId       String   @map("country_id") @db.Uuid
  jurisdictionId  String?  @map("jurisdiction_id") @db.Uuid
  reqType         String   @map("req_type") @db.VarChar(30)
  description     String
  plainDesc       String?  @map("plain_desc")
  isMandatory     Boolean  @default(true) @map("is_mandatory")
  hasAlternatives Boolean  @default(false) @map("has_alternatives")
  alternativesDesc String? @map("alternatives_desc")
  volatilityClass String   @default("MEDIUM") @map("volatility_class") @db.VarChar(6)
  effectiveFrom   DateTime? @map("effective_from") @db.Date
  effectiveTo     DateTime? @map("effective_to") @db.Date
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  country      Country       @relation(fields: [countryId], references: [id])
  jurisdiction Jurisdiction? @relation(fields: [jurisdictionId], references: [id])

  @@map("voter_requirements")
  @@schema("civic")
}

model OfficialDocument {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  countryId       String   @map("country_id") @db.Uuid
  code            String   @db.VarChar(50)
  name            String   @db.VarChar(200)
  purpose         String
  targetPersonas  String[] @default([]) @map("target_personas")
  downloadUrl     String?  @map("download_url") @db.VarChar(500)
  portalUrl       String?  @map("portal_url") @db.VarChar(500)
  processingMin   Int?     @map("processing_min") @db.SmallInt
  processingMax   Int?     @map("processing_max") @db.SmallInt
  requiredDocs    String[] @default([]) @map("required_docs")
  volatilityClass String   @default("MEDIUM") @map("volatility_class") @db.VarChar(6)
  lastVerifiedAt  DateTime? @map("last_verified_at")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  country Country @relation(fields: [countryId], references: [id])

  @@unique([countryId, code])
  @@map("official_documents")
  @@schema("civic")
}

model Persona {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String   @unique @db.VarChar(5)
  name           String   @db.VarChar(100)
  shortLabel     String   @map("short_label") @db.VarChar(50)
  primaryEmotion String?  @map("primary_emotion")
  coreFear       String?  @map("core_fear")
  guidanceMode   String   @default("standard") @map("guidance_mode")
  readingLevel   String   @default("plain") @map("reading_level")
  checklistType  String?  @map("checklist_type")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  blockers PersonaBlocker[]

  @@map("personas")
  @@schema("civic")
}

model PersonaBlocker {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  personaId   String   @map("persona_id") @db.Uuid
  blockerType String   @map("blocker_type") @db.VarChar(15)
  text        String
  sortOrder   Int      @default(0) @map("sort_order") @db.SmallInt
  createdAt   DateTime @default(now()) @map("created_at")

  persona Persona @relation(fields: [personaId], references: [id])

  @@map("persona_blockers")
  @@schema("civic")
}

model Scenario {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String   @unique @db.VarChar(5)
  title          String   @db.VarChar(200)
  severity       String   @db.VarChar(10)
  timing         String?  @db.VarChar(50)
  triggerPhrases String[] @default([]) @map("trigger_phrases")
  isEmergency    Boolean  @default(false) @map("is_emergency")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  resolutionPaths ResolutionPath[]

  @@map("scenarios")
  @@schema("civic")
}

model ResolutionPath {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scenarioId      String   @map("scenario_id") @db.Uuid
  countryId       String   @map("country_id") @db.Uuid
  stepNumber      Int      @map("step_number") @db.SmallInt
  stepText        String   @map("step_text")
  stepType        String   @default("action") @map("step_type") @db.VarChar(15)
  officialContact String?  @map("official_contact") @db.VarChar(200)
  createdAt       DateTime @default(now()) @map("created_at")

  scenario Scenario @relation(fields: [scenarioId], references: [id])
  country  Country  @relation(fields: [countryId], references: [id])

  @@unique([scenarioId, countryId, stepNumber])
  @@map("resolution_paths")
  @@schema("civic")
}

// ── users schema ──────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email             String    @unique @db.VarChar(320)
  passwordHash      String?   @map("password_hash") @db.VarChar(100)
  role              String    @default("REGISTERED_USER") @db.VarChar(20)
  emailVerified     Boolean   @default(false) @map("email_verified")
  emailVerifiedAt   DateTime? @map("email_verified_at")
  oauthProvider     String?   @map("oauth_provider") @db.VarChar(20)
  oauthId           String?   @map("oauth_id") @db.VarChar(200)
  firebaseUid       String?   @unique @map("firebase_uid") @db.VarChar(128)
  preferredCountry  String?   @map("preferred_country") @db.Char(3)
  preferredPersona  String?   @map("preferred_persona") @db.VarChar(5)
  preferredLanguage String    @default("en") @map("preferred_language") @db.Char(5)
  elderlyMode       Boolean   @default(false) @map("elderly_mode")
  highContrast      Boolean   @default(false) @map("high_contrast")
  consentGivenAt    DateTime? @map("consent_given_at")
  consentVersion    String?   @map("consent_version") @db.VarChar(10)
  mfaEnabled        Boolean   @default(false) @map("mfa_enabled")
  mfaSecretEnc      String?   @map("mfa_secret_enc")
  loginAttempts     Int       @default(0) @map("login_attempts") @db.SmallInt
  lockedUntil       DateTime? @map("locked_until")
  fullName          String?   @map("full_name") @db.VarChar(100)
  avatarUrl         String?   @map("avatar_url") @db.VarChar(500)
  isActive          Boolean   @default(true) @map("is_active")

  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  sessions                Session[]
  readinessScores         ReadinessScore[]
  checklistItems          ChecklistItem[]
  notificationPreferences NotificationPreference?
  auditLogs               AuditLog[]
  queryLogs               QueryLog[]

  @@map("users")
  @@schema("users")
}

model Session {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash") @db.VarChar(100)
  userAgent  String?   @map("user_agent") @db.VarChar(500)
  ipAddress  String?   @map("ip_address")
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("users")
}

model ReadinessScore {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  sessionToken   String?  @map("session_token") @db.VarChar(100)
  personaCode    String   @map("persona_code") @db.Char(3)
  countryCode    String   @map("country_code") @db.Char(3)
  score          Int      @default(0) @db.SmallInt
  completedItems String[] @default([]) @map("completed_items")
  totalItems     Int      @default(0) @map("total_items") @db.SmallInt
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("readiness_scores")
  @@schema("users")
}

model ChecklistItem {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  countryCode String    @map("country_code") @db.Char(3)
  itemKey     String    @map("item_key") @db.VarChar(20)
  label       String
  domain      String    @db.VarChar(30)
  status      String    @default("NOT_STARTED") @db.VarChar(15)
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemKey])
  @@map("checklist_items")
  @@schema("users")
}

model NotificationPreference {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId              String   @unique @map("user_id") @db.Uuid
  emailEnabled        Boolean  @default(true) @map("email_enabled")
  smsEnabled          Boolean  @default(false) @map("sms_enabled")
  pushEnabled         Boolean  @default(false) @map("push_enabled")
  subscribedElections String[] @default([]) @map("subscribed_elections")
  reminderLeadDays    Int[]    @default([30, 14, 7, 3, 1]) @map("reminder_lead_days")
  legalAlerts         Boolean  @default(true) @map("legal_alerts")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
  @@schema("users")
}

// ── governance schema ─────────────────────────────────────────────────────────

model SourceRegistry {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String    @unique @db.VarChar(20)
  countryId       String?   @map("country_id") @db.Uuid
  category        String    @db.VarChar(30)
  name            String    @db.VarChar(300)
  url             String?   @db.VarChar(500)
  phone           String?   @db.VarChar(50)
  volatilityClass String    @default("STABLE") @map("volatility_class") @db.VarChar(6)
  lastVerifiedAt  DateTime? @map("last_verified_at")
  linkStatus      String    @default("HEALTHY") @map("link_status") @db.VarChar(15)
  isVerified      Boolean   @default(true) @map("is_verified")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  country     Country?     @relation(fields: [countryId], references: [id])
  civicAxioms CivicAxiom[]

  @@map("source_registry")
  @@schema("governance")
}

model CivicAxiom {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code            String    @unique @db.VarChar(30)
  countryId       String    @map("country_id") @db.Uuid
  category        String    @db.VarChar(20)
  subcategory     String?   @db.VarChar(50)
  fact            String
  plainFact       String?   @map("plain_fact")
  volatilityClass String    @default("STABLE") @map("volatility_class") @db.VarChar(6)
  sourceId        String?   @map("source_id") @db.Uuid
  lastVerifiedAt  DateTime  @default(now()) @map("last_verified_at")
  effectiveFrom   DateTime? @map("effective_from") @db.Date
  effectiveTo     DateTime? @map("effective_to") @db.Date
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  country Country         @relation(fields: [countryId], references: [id])
  source  SourceRegistry? @relation(fields: [sourceId], references: [id])

  @@map("civic_axioms")
  @@schema("governance")
}

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  sessionHash String?  @map("session_hash") @db.VarChar(100)
  action      String   @db.VarChar(50)
  entityType  String?  @map("entity_type") @db.VarChar(50)
  entityId    String?  @map("entity_id") @db.Uuid
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  ipHash      String?  @map("ip_hash") @db.VarChar(100)
  userAgent   String?  @map("user_agent") @db.VarChar(500)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
  @@schema("governance")
}

// ── ai_ops schema ─────────────────────────────────────────────────────────────

model QueryLog {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionHash      String   @map("session_hash") @db.VarChar(100)
  userId           String?  @map("user_id") @db.Uuid
  countryCode      String?  @map("country_code") @db.Char(3)
  personaCode      String?  @map("persona_code") @db.VarChar(5)
  queryIntent      String?  @map("query_intent") @db.VarChar(30)
  confidenceScore  Decimal? @map("confidence_score") @db.Decimal(4, 3)
  safetyPassed     Boolean  @default(true) @map("safety_passed")
  safetyIssues     String[] @default([]) @map("safety_issues")
  modelUsed        String?  @map("model_used") @db.VarChar(50)
  responseMs       Int?     @map("response_ms")
  emergencyMode    Boolean  @default(false) @map("emergency_mode")
  wasHallucination Boolean  @default(false) @map("was_hallucination")
  createdAt        DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@map("query_logs")
  @@schema("ai_ops")
}

// ── ops schema ────────────────────────────────────────────────────────────────

model NotificationJob {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  jobType       String    @map("job_type") @db.VarChar(30)
  userId        String?   @map("user_id") @db.Uuid
  eventId       String?   @map("event_id") @db.Uuid
  payload       Json
  status        String    @default("PENDING") @db.VarChar(10)
  scheduledFor  DateTime  @map("scheduled_for")
  sentAt        DateTime? @map("sent_at")
  attempts      Int       @default(0) @db.SmallInt
  errorMessage  String?   @map("error_message")
  createdAt     DateTime  @default(now()) @map("created_at")

  event ElectionEvent? @relation(fields: [eventId], references: [id])

  @@map("notification_jobs")
  @@schema("ops")
}

model SystemIncident {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  incidentType String    @map("incident_type") @db.VarChar(30)
  severity     String    @db.VarChar(10)
  description  String
  affectedArea String?   @map("affected_area") @db.VarChar(50)
  status       String    @default("ACTIVE") @db.VarChar(15)
  startedAt    DateTime  @default(now()) @map("started_at")
  resolvedAt   DateTime? @map("resolved_at")
  metadata     Json      @default("{}")

  @@map("system_incidents")
  @@schema("ops")
}
