# =============================================================================
# ELECTRA — Environment Variables Template
# Navigate Every Election.
# =============================================================================
# Copy this file to .env.local (development) and fill in values.
# NEVER commit actual secrets to version control.
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# ENVIRONMENT
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=ELECTRA
APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL 16
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://electra_user:electra_pass@localhost:5432/electra_db?schema=public"
DATABASE_URL_TEST="postgresql://electra_user:electra_pass@localhost:5432/electra_test?schema=public"

# ─────────────────────────────────────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_TTL_STABLE=86400       # 24 hours
REDIS_TTL_MEDIUM=3600        # 1 hour
REDIS_TTL_HIGH=300           # 5 minutes

# ─────────────────────────────────────────────────────────────────────────────
# JWT AUTHENTICATION
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_32_CHAR_MINIMUM_SECRET_KEY
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_32_CHAR_SECRET
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH
# ─────────────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=REPLACE_WITH_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=REPLACE_WITH_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# ─────────────────────────────────────────────────────────────────────────────
# AI — GOOGLE GEMINI
# ─────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.5-pro
GEMINI_TEMPERATURE=0.1        # Constitutional AI: deterministic
GEMINI_MAX_TOKENS=1024

# ─────────────────────────────────────────────────────────────────────────────
# API SERVER (NestJS)
# ─────────────────────────────────────────────────────────────────────────────
API_PORT=3001
API_URL=http://localhost:3001
API_CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# ─────────────────────────────────────────────────────────────────────────────
# WEB APP (Next.js)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=ELECTRA
NEXT_PUBLIC_APP_VERSION=1.0.0

# ─────────────────────────────────────────────────────────────────────────────
# ADMIN PANEL (Next.js)
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_PORT=3002
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3001

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_TTL=60             # seconds
RATE_LIMIT_MAX=100            # requests per TTL
AI_RATE_LIMIT_TTL=60
AI_RATE_LIMIT_MAX=20          # AI queries are more expensive

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL (for notifications)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=REPLACE_WITH_SMTP_USER
SMTP_PASS=REPLACE_WITH_SMTP_PASS
EMAIL_FROM=noreply@electra.app

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY
# ─────────────────────────────────────────────────────────────────────────────
ENCRYPTION_KEY=REPLACE_WITH_32_CHAR_AES_KEY
BCRYPT_ROUNDS=12
ADMIN_TOTP_ISSUER=ELECTRA-Admin

# ─────────────────────────────────────────────────────────────────────────────
# CIVIC DATA
# ─────────────────────────────────────────────────────────────────────────────
CIVIC_AXIOM_CACHE_WARM=true
MVP_COUNTRIES=IND,USA,GBR,CAN,AUS
