# =============================================================================
# ELECTRA — Backend Environment Variables (Example)
# =============================================================================

PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
API_CORS_ORIGIN="http://localhost:3000"

# ─── Database (Supabase / Postgres)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Auth (Google OAuth 2.0)
# Generate at: https://console.cloud.google.com
GOOGLE_CLIENT_ID="[ID].apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="[SECRET]"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# ─── JWT Secrets
# Generate using: openssl rand -hex 32
JWT_SECRET="[SECRET_32_HEX]"
JWT_REFRESH_SECRET="[SECRET_32_HEX]"
JWT_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ─── AI (Google Gemini)
# Generate at: https://aistudio.google.com
# Use comma-separated list for rotation: KEY1,KEY2
GEMINI_API_KEY="[YOUR_API_KEY]"
GEMINI_MODEL="gemini-flash-latest"

# ─── Security & Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
BCRYPT_ROUNDS=12

# ─── Redis (Optional - will fallback to in-memory if not set)
# REDIS_URL="rediss://default:[PASSWORD]@[HOST]:[PORT]"

# ─── Notifications (Nodemailer / SendGrid)
MAIL_HOST="smtp.gmail.com"
MAIL_PORT=587
MAIL_USER="alerts@electra.org"
MAIL_PASS="[APP_PASSWORD]"
